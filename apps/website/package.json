{
  "name": "website",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "bun run --bun --env-file=../../.env vite dev",
    "dev:ws": "bun run --bun --env-file=../../.env dev-websocket.ts",
    "build": "bun run --bun --env-file=../../.env vite build",
    "build:prod": "bun run --bun vite build",
    "preview": "bun run --bun --env-file=../../.env vite preview",
    "start": "bun run --bun server.ts",
    "start:preview": "bun run --bun --env-file=../../.env server.ts",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "paraglide:compile": "bun run --bun paraglide-js compile",
    "typecheck": "bun run paraglide:compile && tsc --noEmit",
    "format": "oxfmt .",
    "scan": "bunx react-scan@latest localhost:3000"
  },
