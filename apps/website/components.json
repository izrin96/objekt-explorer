{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "base-nova",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/app.css",
    "baseColor": "zinc",
    "cssVariables": true,
    "prefix": ""
  },
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "iconLibrary": "lucide",
  "menuColor": "default-translucent",
  "menuAccent": "subtle",
  "registries": {
    "@reui": "https://reui.io/r/{style}/{name}.json",
    "@diceui": "https://diceui.com/r/{name}",
    "@kibo-ui": "https://kibo-ui.com/r/{name}.json",
    "@intentui": "https://intentui.com/r/{name}"
  }
}
