{
  "tab_size": 2,
  "hard_tabs": false,
  "preferred_line_length": 100,
  "format_on_save": "on",
  "file_scan_exclusions": [
    "**/routeTree.gen.ts",
    "**/paraglide/**",
    "**/.tanstack/**",
    "**/dist/**",
    "**/.turbo/**",
    "**/lib/**",
    "**/node_modules/**",
    "**/.git/**"
  ],
  "lsp": {
    "tsgo": {
      "settings": {
        "package_version": "7.0.0-dev.20260611.2"
      }
    },
    "oxlint": {
      "settings": {
        "typeAware": true,
        "run": "onSave"
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "tailwindCSS": {
          "lint": {
            "suggestCanonicalClasses": "ignore"
          }
        },
        "classFunctions": ["tv", "twMerge", "twJoin", "composeRenderProps", "composeTailwindRenderProps"]
      }
    }
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["tsgo", "oxlint", "oxfmt", "tailwindcss-language-server", "vtsls", "..."],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports": true
      }
    },
    "TSX": {
      "language_servers": ["tsgo", "oxlint", "oxfmt", "tailwindcss-language-server", "vtsls", "..."],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports": true
      }
    },
    "JavaScript": {
      "language_servers": ["tsgo", "oxlint", "oxfmt", "tailwindcss-language-server", "vtsls", "..."],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "source.organizeImports": true
      }
    }
  }
}
