{
  "name": "@repo/lib",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./server": "./src/server/index.ts",
    "./server/*": "./src/server/*.ts"
  },
  "scripts": {
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "drizzle-orm": "catalog:",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
